{
  "schemaVersion": 1,
  "kind": "sdkwork.commerce.checkout.topology",
  "domain": "commerce",
  "capabilities": {
    "order": {
      "repository": "sdkwork-order",
      "role": "unified-order-center",
      "owns": [
        "commerce_order",
        "commerce_order_item",
        "commerce_order_amount_breakdown",
        "commerce_order_event",
        "commerce_order_cancellation",
        "commerce_recharge_package",
        "commerce_account_value_package",
        "commerce_token_bank_plan",
        "commerce_order_refund_request",
        "commerce_order_withdrawal_request",
        "checkout sessions and product checkout",
        "PSP payment webhook ingestion and payment settlement orchestration",
        "Token Bank recharge and plan purchase orchestration",
        "account value package orders",
        "coupon redemption orders",
        "refund requests",
        "withdrawal requests"
      ],
      "appApiPrefixes": [
        "/app/v3/api/orders",
        "/app/v3/api/recharges",
        "/app/v3/api/checkout",
        "/app/v3/api/memberships"
      ],
      "backendApiPrefixes": [
        "/backend/v3/api/orders"
      ]
    },
    "payment": {
      "repository": "sdkwork-payment",
      "role": "payment-executor",
      "owns": [
        "commerce_payment_intent",
        "commerce_payment_attempt",
        "commerce_payment_record",
        "commerce_refund",
        "commerce_payout",
        "commerce_payment_provider_account",
        "commerce_payment_channel",
        "commerce_payment_webhook_event"
      ],
      "appApiPrefixes": [
        "/app/v3/api/payments"
      ],
      "backendApiPrefixes": [
        "/backend/v3/api/payments"
      ]
    }
  },
  "dependencyDirection": "order -> payment (OwnerOrderPaymentStore, PaymentWebhookStore, provider refund executor, future provider payout executor boundary); order -> account (AccountValueLedgerPort for points, token_bank, cash holds, settlement, release, and reversal); order -> membership (MembershipPurchaseFulfillmentPort wired at OrderServiceHost); payment MUST NOT depend on order service crates; payment MUST NOT depend on account; membership MUST NOT depend on order service crates or insert commerce_order in production",
  "paymentSettlement": {
    "webhookOwner": "order",
    "webhookRoute": "POST /app/v3/api/orders/payments/webhooks/{providerCode}",
    "manualConfirmRoute": "POST /backend/v3/api/orders/{orderId}/payment_confirmations",
    "orchestrator": "sdkwork-order-service::settle_owner_order_after_payment_success",
    "inProcessOnly": true
  },
  "subjectFulfillment": [
    {
      "subject": "points_recharge",
      "handler": "PointsRechargeFulfillmentStore + AccountPointsCreditPort",
      "status": "complete"
    },
    {
      "subject": "token_bank_recharge",
      "handler": "AccountValueLedgerPort credit asset_code=token_bank",
      "status": "implemented-settlement"
    },
    {
      "subject": "token_bank_plan_purchase",
      "handler": "TokenBankPlanOrderStore + AccountValueLedgerPort first-cycle grant asset_code=token_bank",
      "status": "implemented-settlement"
    },
    {
      "subject": "token_bank_plan_renewal",
      "handler": "TokenBankPlanOrderStore + AccountValueLedgerPort renewal grant asset_code=token_bank",
      "status": "implemented-settlement"
    },
    {
      "subject": "account_recharge_package",
      "handler": "AccountValuePackageStore + AccountValueLedgerPort target asset credit",
      "status": "implemented-settlement"
    },
    {
      "subject": "coupon_recharge",
      "handler": "CouponRedemptionPort + AccountValueLedgerPort target asset credit",
      "status": "implemented-settlement"
    },
    {
      "subject": "refund_request",
      "handler": "OrderRefundRequestStore + AccountValueLedgerPort reversal hold + PaymentRefundExecutorPort",
      "status": "implemented-review-execution"
    },
    {
      "subject": "cash_withdrawal",
      "handler": "OrderWithdrawalRequestStore + AccountValueLedgerPort cash hold + future PaymentPayoutExecutorPort; Noop executor fails closed by default",
      "status": "fail-closed-payout"
    },
    {
      "subject": "product",
      "handler": "shipment saga",
      "status": "planned"
    },
    {
      "subject": "virtual_goods",
      "handler": "account or entitlement port",
      "status": "planned"
    },
    {
      "subject": "membership",
      "handler": "MembershipPurchaseFulfillmentPort (sdkwork-order-integration-membership)",
      "status": "complete"
    },
    {
      "subject": "coupon_package",
      "handler": "promotion coupon grant port",
      "status": "planned"
    }
  ],
  "cashier": {
    "urlBuilder": "sdkwork-utils-rust::build_commerce_cashier_url",
    "baseUrlEnv": "SDKWORK_COMMERCE_CASHIER_BASE_URL",
    "defaultBaseUrl": "https://im.sdkwork.com/cashier",
    "queryParams": ["scene", "orderId", "outTradeNo"],
    "orderIdWire": "business order_no (orderSn), not internal UUID",
    "paymentParamsKeys": ["cashierUrl", "nextAction", "orderSn", "cashierScene", "qrCodePayload"]
  },
  "clientSurfaces": {
    "pc": {
      "orderCenter": {
        "standalone": "apps/sdkwork-order-pc",
        "composed": ["sdkwork-mall-pc-checkout", "sdkwork-account-pc-wallet"],
        "sdk": "@sdkwork/order-app-sdk"
      },
      "cashier": {
        "primary": "sdkwork-payment-pc or host shell route /cashier",
        "sdk": "@sdkwork/payment-app-sdk"
      }
    },
    "h5": {
      "orderCenter": "@sdkwork/order-app-sdk via Capacitor/WeChat-H5 shell",
      "cashier": "shared H5 cashier route; deep-link from paymentParams.cashierUrl"
    },
    "flutter": {
      "orderCenter": "Dart facade over order open-api (generated or composed)",
      "cashier": "WebView or native bridge to payment-app-sdk cashier surface"
    }
  },
  "canonicalFlows": {
    "productCheckout": [
      "checkout.sessions.create",
      "checkout.sessions.orders.create",
      "orders.payments.create",
      "paymentParams.cashierUrl -> cashier UI",
      "PSP webhook -> order payments webhooks",
      "order payment settlement -> shipment/fulfillment"
    ],
    "pointsRecharge": [
      "recharges.orders.create",
      "orders.payments.create",
      "paymentParams.cashierUrl -> cashier UI",
      "PSP webhook -> order payments webhooks",
      "order in-process settlement -> account ledger credit"
    ],
    "tokenBankRecharge": [
      "recharges.orders.create subject=token_bank_recharge",
      "orders.payments.create",
      "paymentParams.cashierUrl -> cashier UI",
      "PSP webhook -> order payments webhooks",
      "order in-process settlement -> account ledger credit asset_code=token_bank"
    ],
    "tokenBankPlanPurchase": [
      "recharges.plans.list",
      "recharges.orders.create subject=token_bank_plan_purchase",
      "orders.payments.create",
      "PSP webhook -> order payments webhooks",
      "order settlement -> Token Bank first-cycle grant"
    ],
    "tokenBankPlanRenewal": [
      "renewal scheduler creates subject=token_bank_plan_renewal",
      "orders.payments.create or provider agreement charge",
      "provider callback -> order payment settlement",
      "order settlement -> Token Bank renewal grant"
    ],
    "accountRechargePackage": [
      "recharges.packages.list",
      "recharges.orders.create subject=account_recharge_package",
      "orders.payments.create",
      "order settlement -> account target asset credit"
    ],
    "couponRecharge": [
      "recharges.orders.create subject=coupon_recharge",
      "coupon validation and redemption evidence snapshot",
      "optional mixed-payment orders.payments.create",
      "order settlement -> account target asset credit"
    ],
    "refundRequest": [
      "orders.refundRequests.create references original order",
      "order -> account reversal hold",
      "order -> payment provider refund execution",
      "provider refund success -> account reversal commit",
      "provider refund failure -> account hold release"
    ],
    "cashWithdrawal": [
      "withdrawals.requests.create",
      "order -> account cash hold",
      "default runtime -> NoopPaymentPayoutExecutorPort fails closed because sdkwork-payment has no concrete provider payout executor",
      "current failure path -> account hold release",
      "future provider payout executor success -> account hold settlement"
    ],
    "membershipPurchase": [
      "memberships.orders.create",
      "orders.payments.create",
      "paymentParams.cashierUrl -> cashier UI",
      "PSP webhook -> order payments webhooks",
      "order in-process settlement -> MembershipPurchaseFulfillmentPort"
    ]
  },
  "forbidden": [
    "payment provider HTTP settlement orchestration in sdkwork-payment routes",
    "payment HTTP callback to order backend",
    "insert commerce_order in payment repository",
    "insert commerce_order in membership repository (production; standalone demo exception only)",
    "membership Rust crate dependency on sdkwork-order-service",
    "raw HTTP to order/payment APIs from app packages (use composed SDKs)",
    "direct account SQL writes",
    "payment-owned recharge routes",
    "payment-to-account ledger writes",
    "account-owned recharge/refund/withdrawal orchestration",
    "naked token account naming"
  ]
}
