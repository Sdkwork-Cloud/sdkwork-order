{
  "schemaVersion": 1,
  "kind": "sdkwork.commerce.recharge.spec",
  "capability": "order",
  "domain": "commerce",
  "role": "unified-order-center",
  "ownedTables": [
    "commerce_order",
    "commerce_order_item",
    "commerce_order_amount_breakdown",
    "commerce_order_event",
    "commerce_order_cancellation",
    "commerce_recharge_package"
  ],
  "orderSubjects": {
    "points_recharge": {
      "fulfillment": "account-backend-adjustment",
      "paymentRequired": true
    },
    "product": {
      "fulfillment": "shipment",
      "paymentRequired": true
    },
    "virtual_goods": {
      "fulfillment": "account-or-entitlement",
      "paymentRequired": true
    }
  },
  "ownedApiPrefixes": {
    "app": [
      "/app/v3/api/orders",
      "/app/v3/api/recharges",
      "/app/v3/api/checkout"
    ],
    "backend": [
      "/backend/v3/api/orders"
    ]
  },
  "appOperationIds": {
    "recharges": [
      "recharges.packages.list",
      "recharges.settings.retrieve",
      "recharges.orders.create",
      "recharges.orders.retrieve",
      "recharges.orders.list",
      "recharges.orders.cancel"
    ],
    "orders": [
      "orders.list",
      "orders.retrieve",
      "orders.create",
      "orders.pay",
      "orders.cancel"
    ]
  },
  "upstreamDependencies": [
    {
      "capability": "payment",
      "purpose": "Payment intent and refund execution for existing orderId"
    }
  ],
  "downstreamConsumers": [
    {
      "capability": "account",
      "purpose": "Ledger adjustments on virtual fulfillment"
    },
    {
      "capability": "account-pc-wallet",
      "purpose": "Recharge UI via order-app-sdk"
    },
    {
      "capability": "mall-pc-checkout",
      "purpose": "Product checkout via checkout.* and orders.pay"
    },
    {
      "capability": "payment-pc",
      "purpose": "Cashier UI for paymentParams.cashierUrl"
    }
  ],
  "clientIntegrationMatrix": {
    "pc": {
      "orderCenter": "apps/sdkwork-order-pc",
      "checkout": "sdkwork-mall-pc-checkout",
      "cashier": "sdkwork-payment-pc",
      "sdk": "@sdkwork/order-app-sdk"
    },
    "h5": {
      "orderCenter": "host shell + @sdkwork/order-app-sdk",
      "cashier": "H5 route at SDKWORK_COMMERCE_CASHIER_BASE_URL"
    },
    "flutter": {
      "orderCenter": "composed order open-api facade",
      "cashier": "WebView or native payment bridge"
    }
  },
  "forbidden": [
    "payment provider HTTP in order routes",
    "direct writes to commerce_account ledger",
    "recharge order creation in payment repository (target state)"
  ],
  "sdkPortsExtension": {
    "file": "apps/sdkwork-order-common/packages/sdkwork-order-sdk-ports/src/index.ts",
    "addTree": {
      "recharges": {
        "packages": { "list": true },
        "settings": { "retrieve": true },
        "orders": {
          "create": true,
          "retrieve": true,
          "list": true,
          "cancel": true
        }
      }
    }
  },
  "migrationFromPayment": {
    "status": "complete",
    "deprecationPolicy": "Payment /recharges/* proxy is opt-in (SDKWORK_PAYMENT_ENABLE_RECHARGE_PROXY=1); local recharge handlers removed; clients use order app-api"
  },
  "implementationPhases": [
    {
      "id": "O1",
      "title": "Recharge boundary specs frozen",
      "status": "complete"
    },
    {
      "id": "O2",
      "title": "Extend order-sdk-ports + OpenAPI recharges paths",
      "status": "complete"
    },
    {
      "id": "O3",
      "title": "Migrate recharge repository from payment to order",
      "status": "complete"
    },
    {
      "id": "O4",
      "title": "orders.pay saga + account adjustment integration test",
      "status": "complete",
      "blockedBy": ["O3"]
    },
    {
      "id": "O5",
      "title": "Remove payment insert_order in recharge",
      "status": "complete",
      "blockedBy": ["O4"]
    },
    {
      "id": "O6",
      "title": "Gateway closure: account credit adapter + backend fulfillment saga + payment confirmation",
      "status": "complete",
      "blockedBy": ["O5"],
      "deliverables": [
        "sdkwork-order-integration-account (http|store AccountPointsCreditPort)",
        "POST /backend/v3/api/orders/{orderId}/payment_confirmations",
        "Order backend IAM web-framework wrap"
      ]
    },
    {
      "id": "O7",
      "title": "Recharge app-api SdkWorkApiResponse v3 envelope",
      "status": "complete",
      "blockedBy": ["O6"]
    },
    {
      "id": "O8",
      "title": "Order app-api SdkWorkApiResponse v3 envelope (checkout, fulfillment, shipment, after_sales, orders)",
      "status": "complete",
      "blockedBy": ["O7"],
      "deliverables": [
        "checkout_router.rs",
        "fulfillment_router.rs",
        "shipment_router.rs",
        "after_sales_router.rs",
        "order_router.rs",
        "backend_order_admin_router.rs"
      ]
    },
    {
      "id": "O9",
      "title": "OpenAPI + order-app-sdk regeneration for v3 envelope",
      "status": "complete",
      "blockedBy": ["O8"],
      "deliverables": [
        "apis/app-api/order/order-app-api.openapi.json",
        "sdks/sdkwork-order-app-sdk/openapi/sdkwork-order-app-api.openapi.json",
        "pnpm sdk:generate"
      ]
    },
    {
      "id": "O10",
      "title": "Store-layer E2E: payment success → fulfill → account ledger",
      "status": "complete",
      "blockedBy": ["O9"],
      "deliverables": [
        "sdkwork-order-integration-account/tests/points_recharge_store_e2e_standard.rs",
        "sdkwork-order-repository-sqlx/test_migrations/0001_order_points_recharge_e2e.sql",
        "test-support feature on order/account repository-sqlx crates"
      ]
    },
    {
      "id": "O11",
      "title": "Checkout topology + cashier URL alignment with payment",
      "status": "complete",
      "blockedBy": ["O10"],
      "deliverables": [
        "specs/commerce-checkout-topology.spec.json",
        "docs/architecture/commerce/COMMERCE_CHECKOUT_ARCHITECTURE.md",
        "sdkwork-utils-rust::build_commerce_cashier_url",
        "payment fulfillment callback path points_recharge (snake_case)"
      ]
    },
    {
      "id": "O12",
      "title": "Webhook-driven payment settlement (payment-owned; superseded by O13)",
      "status": "superseded",
      "supersededBy": "O13",
      "blockedBy": ["O11"]
    },
    {
      "id": "O13",
      "title": "Order-owned PSP webhooks + in-process settlement (payment -X-> order)",
      "status": "complete",
      "blockedBy": ["O12"],
      "deliverables": [
        "POST /app/v3/api/orders/payments/webhooks/{providerCode}",
        "POST /backend/v3/api/orders/{orderId}/payment_confirmations",
        "sdkwork-order-service::settle_owner_order_after_payment_success",
        "payment webhook 410 Gone shim on sdkwork-payment",
        "specs/commerce-payment-webhook.spec.json"
      ]
    }
  ],
  "backendOperationIds": {
    "orders": [
      "orders.paymentConfirmations.create",
      "orders.pointsRecharge.fulfillments.create"
    ]
  }
}
