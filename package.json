{
  "name": "sdkwork-order-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "stop": "node ../sdkwork-specs/tools/stop-sdkwork-workspace-processes.mjs --workspace .",    "dev": "pnpm --dir apps/sdkwork-order-pc dev",
    "build": "pnpm --dir apps/sdkwork-order-pc build",
    "start": "cargo run -p sdkwork-order-standalone-gateway --bin sdkwork-order-standalone-gateway",
    "test": "pnpm test:node && pnpm test:vitest && cargo test --workspace",
    "test:node": "node --test --test-reporter=spec tests/static/openapi-contract.test.mjs",
    "test:vitest": "vitest run --config vitest.config.ts --configLoader native --pool vmThreads",
    "test:postgres": "node scripts/test/postgres-parity.mjs",
    "test:postgres:required": "node scripts/test/postgres-parity.mjs --require-database",
    "check:governance": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace . && node ../sdkwork-specs/tools/check-pagination.mjs --workspace . && node ../sdkwork-specs/tools/check-app-sdk-consumer-imports.mjs --workspace .",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm test:vitest && cargo test --workspace && pnpm run check:app-composition && pnpm run check:governance",
    "fmt:rust:check": "cargo fmt --all -- --check",
    "check": "pnpm run check:app-composition && pnpm db:validate && pnpm gateway:assembly:validate && pnpm fmt:rust:check",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_order_baseline.sql --module-id order --owner sdkwork-order --prefixes commerce_ --engines postgres,sqlite",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "gateway:assembly:materialize": "node scripts/gateway/assembly-materialize.mjs",
    "gateway:assembly:validate": "node scripts/gateway/assembly-validate.mjs",
    "sync:openapi": "node -e \"const fs=require('fs');const p=[['apis/app-api/order/order-app-api.openapi.json','sdks/sdkwork-order-app-sdk/openapi/sdkwork-order-app-api.openapi.json'],['apis/app-api/order/order-app-api.openapi.json','sdks/sdkwork-order-app-sdk/openapi/sdkwork-order-app-api.sdkgen.json'],['apis/backend-api/order/order-backend-api.openapi.json','sdks/sdkwork-order-backend-sdk/openapi/sdkwork-order-backend-api.openapi.json']];for(const [s,d] of p){fs.copyFileSync(s,d);}console.log('synced openapi authorities to sdk families');\"",
    "prune:openapi": "node scripts/openapi/prune-legacy-openapi.mjs",
    "align:openapi": "node ../sdkwork-specs/tools/align-openapi-response-envelope.mjs --file apis/app-api/order/order-app-api.openapi.json --legacy-envelope CommerceApiResult",
    "sdk:generate": "node sdks/sdkwork-order-app-sdk/bin/generate-sdk.mjs",
    "sdk:generate:backend": "node sdks/sdkwork-order-backend-sdk/bin/generate-sdk.mjs",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root ."
  },
  "devDependencies": {
    "@sdkwork/appbase-pc-react": "workspace:*",
    "@sdkwork/ui-pc-react": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "lucide-react": "^1.7.0"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
